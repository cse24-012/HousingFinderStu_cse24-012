<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:padding="16dp">

    <!-- ========== TOP BAR / HEADER ========== -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@drawable/header_gradient">

            <!-- Title with Icon -->
            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="CampusCrib"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Profile Button -->
            <Button
                android:id="@+id/btnProfile"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="26dp"
                android:layout_toStartOf="@+id/textView"
                android:background="@drawable/button_rounded_white"
                android:paddingHorizontal="12dp"
                android:text="👤 Profile"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <!-- Logout Button -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="28dp"
                android:layout_toEndOf="@+id/textView"
                android:background="@drawable/button_rounded_white"
                android:paddingHorizontal="12dp"
                android:text="🚪 Logout"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

    <!-- ========== FILTER SECTION CARD ========== -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#FFFFFF">

            <!-- Filter Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍 Filter Listings"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"/>

            <!-- Row 1: Price Range -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 Price:"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etMinPrice"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="Min BWP"
                    android:inputType="number"
                    android:background="@drawable/edittext_light_rounded"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etMaxPrice"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="Max BWP"
                    android:inputType="number"
                    android:background="@drawable/edittext_light_rounded"
                    android:paddingHorizontal="12dp"/>

            </LinearLayout>

            <!-- Row 2: Location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Location:"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"/>

                <Spinner
                    android:id="@+id/spinnerLocation"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/spinner_bg"
                    android:paddingHorizontal="12dp"/>

            </LinearLayout>

            <!-- Row 3: Availability Date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Available by:"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etAvailabilityDate"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="YYYY-MM-DD"
                    android:inputType="date"
                    android:background="@drawable/edittext_light_rounded"
                    android:paddingHorizontal="12dp"/>

            </LinearLayout>

            <!-- Filter Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnFilter"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="🔍 Apply Filter"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_primary"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnClearFilter"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="🗑️ Clear"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@drawable/button_secondary"
                    android:backgroundTint="#EEEEEE"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- ========== EXTENSION FEATURE: NAVIGATION BUTTON ========== -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnNavigation"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🗺️ Route to Campus (Extension Feature)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_navigation"
            android:paddingHorizontal="16dp"/>

    </androidx.cardview.widget.CardView>

    <!-- ========== LISTINGS RECYCLER VIEW ========== -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏠 Available Properties"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHouses"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

</LinearLayout>