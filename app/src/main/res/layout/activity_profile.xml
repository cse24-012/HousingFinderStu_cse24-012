<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👤 My Profile"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <!-- User Info Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User Information"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:padding="8dp"/>

    <TextView
        android:id="@+id/tvUserEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:padding="8dp"
        android:layout_marginBottom="16dp"/>

    <!-- Smart Alerts Preferences Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔔 Smart Alert Preferences"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You'll get notifications when houses match these preferences"
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="16dp"/>

    <!-- Preferred Location -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Preferred Location (e.g., Gaborone West, CBD)"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etPrefLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter area name"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <!-- Max Price -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Maximum Monthly Price (BWP)"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etPrefMaxPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g., 5000"
        android:inputType="number"
        android:layout_marginBottom="24dp"/>

    <!-- Save Button -->
    <Button
        android:id="@+id/btnSavePreferences"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💾 Save Alert Preferences"
        android:backgroundTint="@android:color/holo_blue_dark"/>

    <!-- Back Button -->
    <Button
        android:id="@+id/btnBackToMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← Back to Main"
        android:backgroundTint="@android:color/darker_gray"
        android:layout_marginTop="16dp"/>

</LinearLayout>